{
    "manifest_version": 2,
    "name": "Turnstile Patch",
    "version": "1.0.0",
    "description": "Patch browser automation detection for Turnstile",
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "permissions": ["activeTab"]
}
